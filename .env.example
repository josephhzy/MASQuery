# ────────────────────────────────────────────────────────────────────────
# LLM provider + key. Default: openai / gpt-5-nano.
# Local:           copy this file to `.env` and paste your key below.
# Streamlit Cloud: paste these as key=value pairs in the app's Secrets panel
#                  (they auto-load as env vars).
# Railway/Render:  set them as project env vars in the dashboard.
# GitHub Actions:  set them as repo Secrets, then reference via ${{ secrets.OPENAI_API_KEY }}.
# ────────────────────────────────────────────────────────────────────────

# Required: key for the active provider
OPENAI_API_KEY=sk-xxxxx

# Optional: swap to anthropic by uncommenting and filling ANTHROPIC_API_KEY
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional overrides (safe defaults if unset)
LLM_PROVIDER=openai
OPENAI_MODEL=gpt-5-nano
SEARCH_MODE=vector
RERANK_ENABLED=true

# Dashboard -> API wiring.
# Local:           leave as http://localhost:8000
# Streamlit Cloud: set to your deployed backend URL (Railway/Render/Fly).
API_BASE_URL=http://localhost:8000
